# Environment for the standalone Projects service (fractera-projects, :3003) — step 197.
# bootstrap.sh writes the real .env.local from these keys. The zone/automations break silently
# without them, so this file is the authoritative checklist.

# --- Auth (browser redirects + server session read) ---
AUTH_SERVICE_URL=http://localhost:3001
# FRACTERA_IP_NODOMAIN_MODE=true opens the zone in IP/onboarding mode (auth bypass).

# --- DATA / MEDIA (fractera-data :3300) — #1 FAILURE TRAP ---
# BOTH must be set or lib/db falls back to an in-process empty SQLite file and sees NONE of the
# owner's rows. DATA_API_KEY MUST equal the data service's DATA_SECRET.
REMOTE_DATA_URL=http://localhost:3300
DATA_API_KEY=

# --- MEMORY (fractera-rag / LightRAG :9621) ---
LIGHTRAG_URL=http://localhost:9621
LIGHTRAG_API_KEY=

# --- Cross-service ---
# Admin, for the OpenAI-key forwarder (/api/project-config/openai-key -> :3002/api/config/hermes).
ADMIN_INTERNAL_URL=http://localhost:3002
# Shared substrate multi-bot registry the Telegram listener polls (register-bot writes here).
AUTOMATIONS_REGISTRY_PATH=/opt/fractera/services/automations-listener/registry.json
# Public base for absolute media/preview links returned into chat (the media-proxy route
# served by THIS process). In domain mode: https://projects.<apex> ; IP mode: http://<ip>:3003.
APP_BASE_URL=http://localhost:3003

# --- Slot data reads (slotRoot()-style helpers), if any project reads slot files ---
SLOT_DIR=/opt/fractera/app

# --- Integration keys for the running automations (set per-automation via the keys modal;
#     the env setter writes them into THIS app's .env.local after the move) ---
# TELEGRAM_BOT_TOKEN=
# OPENAI_API_KEY=
