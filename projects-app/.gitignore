.next/
node_modules/
.env.local
tsconfig.tsbuildinfo

# RUNTIME JOURNALS (block 4 of the file-system refactor) — an automations runs, rows and
# instances live in _data/runtime/*.jsonl. This is DATA, not code: it grows on every run and
# differs per server, exactly like the app.db it replaced. Pull it on demand, never commit it.
_data/runtime/

# SWC cache — written by the compiler on every build.
/.swc

# WORKSPACE STATE — пишется кликами владельца на общем холсте (позиции узлов, вложенность, глобальный
# статус: lib/edges.ts writeGlobalState). Это ДАННЫЕ сервера, а не исходник: файл менялся на каждом
# перетаскивании и молча срывал `git pull`. Отсутствует — читатель честно возвращает пустую раскладку
# и статус "in-development", поэтому свежему серверу файл в репозитории не нужен.
app/(projects)/projects/_data/global-automation.json

# ГРАФ РОЖДЁННОЙ АВТОМАТИЗАЦИИ — тоже данные: рантайм переписывает `updatedAt` на каждом прогоне (файл
# менялся даже во время сборки). Рождённые автоматизации создаются НА СЕРВЕРЕ, их состоянию в репозитории
# не место. Отслеживался ровно один такой файл — у тестовой `test-stream-frozen-starter`.
app/(projects)/projects/other/test-stream-frozen-starter/_data/graph.json
